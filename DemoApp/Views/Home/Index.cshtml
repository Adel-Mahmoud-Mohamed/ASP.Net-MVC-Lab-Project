@model DemoApp.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card text-white bg-primary h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Departments</h5>
                    <p class="card-text display-6">@Model.DepartmentsCount</p>
                    <a asp-controller="Department" asp-action="Index" class="btn btn-light mt-auto">Manage Departments</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text display-6">@Model.CoursesCount</p>
                    <a asp-controller="Course" asp-action="Index" class="btn btn-light mt-auto">Manage Courses</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Students</h5>
                    <p class="card-text display-6">@Model.StudentsCount</p>
                    <a asp-controller="Student" asp-action="Index" class="btn btn-light mt-auto">Manage Students</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Recent Students</div>
                <div class="card-body p-0">
                    @if (Model.RecentStudents != null && Model.RecentStudents.Any())
                    {
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name</th>
                                    <th>Dept</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.RecentStudents)
                                {
                                    <tr>
                                        <td>@s.Id</td>
                                        <td>@s.Name</td>
                                        <td>@s.Department?.DeptName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-3 text-muted">No recent students.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Recent Courses</div>
                <div class="card-body p-0">
                    @if (Model.RecentCourses != null && Model.RecentCourses.Any())
                    {
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>CrsId</th>
                                    <th>Name</th>
                                    <th>Duration</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.RecentCourses)
                                {
                                    <tr>
                                        <td>@c.CrsId</td>
                                        <td>@c.Name</td>
                                        <td>@c.Duration</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-3 text-muted">No recent courses.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Quick Actions</h5>
                    <p>
                        <a asp-controller="Student" asp-action="Create" class="btn btn-outline-primary me-2">Add Student</a>
                        <a asp-controller="Department" asp-action="Create" class="btn btn-outline-secondary me-2">Add Department</a>
                        <a asp-controller="Course" asp-action="Create" class="btn btn-outline-success">Add Course</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
