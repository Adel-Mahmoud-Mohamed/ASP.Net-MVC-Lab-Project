@model IEnumerable<ITIEntities.Model.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">Courses</h1>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>CrsId</th>
                        <th>Name</th>
                        <th>Duration</th>
                        <th>Departments</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var c in Model)
                        {
                            <tr>
                                <td>@c.CrsId</td>
                                <td>@c.Name</td>
                                <td>@c.Duration</td>
                                <td>@(c.Departments != null ? string.Join(", ", c.Departments.Select(d => d.DeptName)) : "")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@c.CrsId" class="btn btn-info btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@c.CrsId" class="btn btn-warning btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@c.CrsId" class="btn btn-danger btn-sm">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">No courses found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>