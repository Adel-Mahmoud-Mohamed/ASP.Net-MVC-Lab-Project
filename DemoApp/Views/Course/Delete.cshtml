@model ITIEntities.Model.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 text-danger">Delete Course</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <p class="lead">Are you sure you want to delete the following course?</p>

            <dl class="row">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.CrsId</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@Model.Duration</dd>

                <dt class="col-sm-3">Departments</dt>
                <dd class="col-sm-9">@((Model.Departments != null) ? string.Join(", ", Model.Departments.Select(d => d.DeptName)) : "")</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.CrsId" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CrsId" />
                <button type="submit" class="btn btn-danger">Yes, delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>