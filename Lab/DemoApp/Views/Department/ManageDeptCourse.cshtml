@model ITIEntities.Model.Department

@{
    ViewData["Title"] = "Manage Courses for Department";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4">Manage courses for @Model.DeptName</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="row">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header">Assigned Courses (@(Model.Courses?.Count ?? 0))</div>
                <div class="card-body p-2">
                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        <ul class="list-group">
                            @foreach (var c in Model.Courses)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                    
                                     <div>
                                        <strong>@c.Name</strong>
                                        <div class="text-muted small">Duration: @c.Duration</div>
                                    </div>
                                    <div>
                                        <input form="manageForm" type="checkbox" name="coursestoremove" value="@c.CrsId" class="form-check-input" />
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted">No courses assigned to this department.</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-2 d-flex align-items-center justify-content-center">
            <div class="text-center">
                <button form="manageForm" type="submit" class="btn btn-primary mb-2">Update</button>
                <div class="small text-muted">Select checkboxes to add/remove then press Update</div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card">
                <div class="card-header">Available Courses (@(ViewBag.CoursesNotInDept?.Count ?? 0))</div>
                <div class="card-body p-2">
                    @if (ViewBag.CoursesNotInDept != null && ((System.Collections.IEnumerable)ViewBag.CoursesNotInDept).Cast<object>().Any())
                    {
                        <ul class="list-group">
                            @foreach (var c in ViewBag.CoursesNotInDept)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@c.Name</strong>
                                        <div class="text-muted small">Duration: @c.Duration</div>
                                    </div>
                                    <div>
                                        <input form="manageForm" type="checkbox" name="coursestoadd" value="@c.CrsId" class="form-check-input" />
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-muted">No available courses to add.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <form id="manageForm" asp-action="ManageDeptCourse" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.DeptId" />
    </form>
</div>

