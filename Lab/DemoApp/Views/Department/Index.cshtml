@model IEnumerable<ITIEntities.Model.Department>

@{
    ViewData["Title"] = "Departments";
}

<h1 class="h3">Departments</h1>

<div class="mb-3">
    <a asp-controller="Department" asp-action="Create" class="btn btn-primary">
        Create New
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col">Dept ID</th>
                    <th scope="col">Name</th>
                    <th scope="col">Capacity</th>
                    <th scope="col">Students</th>
                    <th scope="col">Courses</th>
                    <th scope="col"></th>

                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var dept in Model)
                    {
                        <tr>
                            <td>@dept.DeptId</td>
                            <td>@dept.DeptName</td>
                            <td>@dept.Capacity</td>
                            <td>@(dept.Students?.Count ?? 0)</td>
                            <td>@(dept.Courses?.Count ?? 0)</td>

                            <td>
                                <a asp-action="Details" asp-controller="department" asp-route-id="@dept.DeptId" class="btn btn-info">Details</a>|
                                <a asp-action="Edit" asp-controller="department" asp-route-id="@dept.DeptId" class="btn btn-warning">Edit</a>|
                                <a asp-action="ManageDeptCourse" asp-controller="department" asp-route-id="@dept.DeptId" class="btn btn-warning">update courses</a>|
                                <a asp-action="Delete" asp-controller="department" asp-route-id="@dept.DeptId" class="btn btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4">No departments found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

