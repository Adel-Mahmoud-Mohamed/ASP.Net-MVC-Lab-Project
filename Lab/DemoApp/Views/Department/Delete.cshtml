@model ITIEntities.Model.Department

@{
    ViewData["Title"] = "Delete Department";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 text-danger">Delete Department</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="card border-danger shadow-sm">
        <div class="card-body">
            <p class="lead">Are you sure you want to delete the following department?</p>

            <dl class="row">
                <dt class="col-sm-3">Department ID</dt>
                <dd class="col-sm-9">@Model.DeptId</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.DeptName</dd>

                <dt class="col-sm-3">Capacity</dt>
                <dd class="col-sm-9">@Model.Capacity</dd>

                <dt class="col-sm-3">Students</dt>
                <dd class="col-sm-9">@(@Model.Students?.Count ?? 0)</dd>

                <dt class="col-sm-3">Courses</dt>
                <dd class="col-sm-9">@(@Model.Courses?.Count ?? 0)</dd>
            </dl>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-header">Students in this department</div>
                        <div class="card-body p-0">
                            @if (Model.Students != null && Model.Students.Any())
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var s in Model.Students)
                                    {
                                        <li class="list-group-item">@s.Name <small class="text-muted">(@s.Email)</small></li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="p-3 text-muted">No students assigned.</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-header">Courses for this department</div>
                        <div class="card-body p-0">
                            @if (Model.Courses != null && Model.Courses.Any())
                            {
                                <ul class="list-group list-group-flush">
                                    @foreach (var c in Model.Courses)
                                    {
                                        <li class="list-group-item">@c.Name <small class="text-muted">(@c.Duration) hrs</small></li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="p-3 text-muted">No courses assigned.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.DeptId" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="DeptId" />
                <button type="submit" class="btn btn-danger">Yes, delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
