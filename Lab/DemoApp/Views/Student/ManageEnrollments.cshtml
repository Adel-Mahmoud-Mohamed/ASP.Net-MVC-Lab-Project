@model ITIEntities.Model.Student

@{
    ViewData["Title"] = "Manage Enrollments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4">Manage enrollments for @Model.Name</h1>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Student</a>
    </div>

    <form asp-action="ManageEnrollments" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="card mb-3">
            <div class="card-header">Currently Enrolled</div>
            <div class="card-body p-0">
                @if (Model.StudentCourses != null && Model.StudentCourses.Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Degree</th>
                                <th>Remove</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.StudentCourses)
                            {
                                <tr>
                                    <td>@sc.Course?.Name</td>
                                    <td>@(sc.Degree?.ToString() ?? "-")</td>
                                    <td>
                                        <input type="checkbox" name="coursestoremove" value="@sc.CrsNo" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3 text-muted">Student is not enrolled in any courses.</div>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Available Courses in Department (@(ViewBag.AvailableCourses?.Count ?? 0))</div>
            <div class="card-body p-0">
                @if (ViewBag.AvailableCourses != null && ((System.Collections.IEnumerable)ViewBag.AvailableCourses).Cast<object>().Any())
                {
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Course</th>
                                <th>Duration</th>
                                <th>Add</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in ViewBag.AvailableCourses)
                            {
                                <tr>
                                    <td>@c.Name</td>
                                    <td>@c.Duration</td>
                                    <td><input type="checkbox" name="coursestoadd" value="@c.CrsId" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3 text-muted">No available courses in student's department.</div>
                }
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="submit" class="btn btn-primary">Update Enrollments</button>
        </div>
    </form>
</div>