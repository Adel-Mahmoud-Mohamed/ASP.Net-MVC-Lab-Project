@model ITIEntities.Model.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">Course Details</h1>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.CrsId</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@Model.Duration</dd>

                <dt class="col-sm-3">Departments</dt>
                <dd class="col-sm-9">@((Model.Departments != null) ? string.Join(", ", Model.Departments.Select(d => d.DeptName)) : "")</dd>
            </dl>
        </div>
    </div>

    <div class="card">
        <div class="card-header">Enrolled Students</div>
        <div class="card-body p-0">
            @if (Model.CourseStudents != null && Model.CourseStudents.Any())
            {
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Degree</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sc in Model.CourseStudents)
                        {
                            <tr>
                                <td>@sc.Student?.Name</td>
                                <td>@sc.Degree</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="p-3 text-muted">No students enrolled in this course.</div>
            }
        </div>
    </div>
</div>